---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;

type ProjectWithExtras = (typeof projects)[number] & {
  previewLinks?: { label: string; href: string }[];
};
---

<Section text="Featured Projects" href="projects">
  {
    (projects as ProjectWithExtras[]).map(({ name, summary, image, linkPreview, linkSource, previewLinks }, index) => {
      const top = 98 + index * 40;
      return (
        <div
          style={`top: ${top}px;`}
          class="sticky mb-12 rounded-2xl border border-neutral/20 bg-black"
        >
          <div class="bg-difu relative z-[1] grid h-auto w-full grid-rows-2 rounded-2xl bg-[#1c232d]/85 before:absolute before:inset-0 before:z-[-1] before:rounded-2xl before:bg-[url(/raja.png)] before:bg-[length:128px] before:bg-repeat before:opacity-[5%] before:content-[''] sm:grid-cols-2 sm:grid-rows-1 md:h-[560px]">
            <div class="px-6 pt-12 pb-10">
              <h3 class="mb-5 font-serif text-3xl font-medium text-primary">
                {name}
              </h3>
              <p class="text-base text-neutral">{summary}</p>
              <div class="pt-10 text-white">
                {previewLinks && previewLinks.length > 0 ? (
                  <ul class="flex flex-col gap-2">
                    {previewLinks.map(({ label, href }) => (
                      <li>
                        <a
                          href={href}
                          target="_blank"
                          class="after:relative after:bottom-[-5px] after:content-[url(/external.svg)] hover:underline"
                        >
                          {label}
                        </a>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <div class="flex gap-5">
                    {linkSource && (
                      <a
                        href={linkSource}
                        target="_blank"
                        class="after:relative after:bottom-[-5px] after:content-[url(/external.svg)] hover:underline"
                      >
                        Source
                      </a>
                    )}
                    {linkPreview && (
                      <a
                        href={linkPreview}
                        target="_blank"
                        class="after:relative after:bottom-[-5px] after:content-[url(/external.svg)] hover:underline"
                      >
                        Preview
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
            <div class="flex items-end justify-end overflow-hidden">
              <Image
                class="h-[280px] w-[95%] rounded-ss-xl rounded-ee-2xl object-cover sm:h-full sm:w-full"
                src={image}
                alt={name}
                width="736"
                height="560"
              />
            </div>
          </div>
        </div>
      );
    })
  }
</Section>
